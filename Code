        // =============== LEVEL 1: SHAPES GAME - FIXED ===============
        function initializeShapesGame() {
            const container = document.getElementById('shapesGameContainer');
            container.innerHTML = '';
            shapesPlaced = 0;
           
            // Define shapes with their properties
            const shapes = [
                {
                    type: 'circle',
                    color: '#a8d8ea',
                    name: 'Circle',
                    emoji: '⭕'
                },
                {
                    type: 'square',
                    color: '#c7f0d8',
                    name: 'Square',
                    emoji: '⬜'
                },
                {
                    type: 'triangle',
                    color: '#ffd6e7',
                    name: 'Triangle',
                    emoji: '🔺'
                },
                {
                    type: 'rectangle',
                    color: '#fff9c4',
                    name: 'Rectangle',
                    emoji: '📏'
                },
                {
                    type: 'star',
                    color: '#d8c7ff',
                    name: 'Star',
                    emoji: '⭐'
                },
                {
                    type: 'heart',
                    color: '#ffb6c1',
                    name: 'Heart',
                    emoji: '❤️'
                }
            ];
           
            totalShapes = shapes.length;
           
            // Create two rows
            const outlineRow = document.createElement('div');
            outlineRow.className = 'shapes-row';
            outlineRow.id = 'outlineRow';
           
            const shapeRow = document.createElement('div');
            shapeRow.className = 'shapes-row';
            shapeRow.id = 'shapeRow';
           
            // Create shape outlines (drop zones) in first row
            shapes.forEach((shape, index) => {
                const shapeItem = document.createElement('div');
                shapeItem.className = 'shape-item';
               
                const outline = document.createElement('div');
                outline.className = `shape-outline ${shape.type}`;
                outline.id = `outline-${index}`;
                outline.dataset.shapeType = shape.type;
               
                const label = document.createElement('div');
                label.className = 'shape-label';
                label.textContent = shape.name;
               
                shapeItem.appendChild(outline);
                shapeItem.appendChild(label);
                outlineRow.appendChild(shapeItem);
               
                // Add drop event listener
                outline.addEventListener('dragover', handleDragOver);
                outline.addEventListener('drop', handleDrop);
                outline.addEventListener('touchmove', handleTouchMove, { passive: false });
                outline.addEventListener('touchend', handleTouchEnd);
            });
           
            // Create draggable shapes in second row (shuffled)
            const shuffledShapes = [...shapes].sort(() => Math.random() - 0.5);
           
            shuffledShapes.forEach((shape, index) => {
                const shapeItem = document.createElement('div');
                shapeItem.className = 'shape-item';
               
                const shapeElement = document.createElement('div');
                shapeElement.className = `shape ${shape.type}`;
                shapeElement.id = `shape-${index}`;
                shapeElement.dataset.shapeType = shape.type;
                shapeElement.dataset.originalIndex = shapes.findIndex(s => s.type === shape.type);
                shapeElement.draggable = true;
                shapeElement.textContent = shape.emoji;
               
                // Set color based on shape type
                if (shape.type === 'triangle') {
                    shapeElement.style.borderBottomColor = shape.color;
                } else if (shape.type === 'star' || shape.type === 'heart') {
                    // Already handled by CSS
                } else {
                    shapeElement.style.backgroundColor = shape.color;
                }
               
                const label = document.createElement('div');
                label.className = 'shape-label';
                label.textContent = shape.name;
               
                shapeItem.appendChild(shapeElement);
                shapeItem.appendChild(label);
                shapeRow.appendChild(shapeItem);
               
                // Add drag event listeners
                shapeElement.addEventListener('dragstart', handleDragStart);
                shapeElement.addEventListener('dragend', handleDragEnd);
               
                // Add touch event listeners for mobile
                shapeElement.addEventListener('touchstart', handleTouchStart, { passive: false });
            });
           
            container.appendChild(outlineRow);
            container.appendChild(shapeRow);
        }

        function handleDragStart(e) {
            e.dataTransfer.setData('text/plain', e.target.id);
            e.target.classList.add('dragging');
            setTimeout(() => {
                e.target.style.opacity = '0.4';
            }, 0);
        }

        function handleDragEnd(e) {
            e.target.classList.remove('dragging');
            e.target.style.opacity = '1';
        }

        function handleDragOver(e) {
            e.preventDefault();
        }

        function handleDrop(e) {
            e.preventDefault();
            const id = e.dataTransfer.getData('text/plain');
            const draggable = document.getElementById(id);
            const dropzone = e.target;
           
            // Check if we're dropping on an outline
            if (!dropzone.classList.contains('shape-outline')) return;
           
            // Check if shape matches outline
            const shapeType = draggable.dataset.shapeType;
            const outlineType = dropzone.dataset.shapeType;
           
            if (shapeType === outlineType) {
                // Position the shape inside the outline
                draggable.style.position = 'absolute';
                draggable.style.top = '50%';
                draggable.style.left = '50%';
                draggable.style.transform = 'translate(-50%, -50%)';
                draggable.style.margin = '0';
                dropzone.appendChild(draggable);
               
                // Make it non-draggable after correct placement
                draggable.draggable = false;
                draggable.classList.remove('dragging');
                draggable.style.opacity = '1';
                draggable.style.cursor = 'default';
               
                // Remove touch events
                draggable.ontouchstart = null;
               
                shapesPlaced++;
               
                // Show success message
                showSuccessAnimation(dropzone);
                showMessage("Perfect! You found the right home for the " + draggable.dataset.shapeType);
               
                // Check if all shapes are placed
                if (shapesPlaced === totalShapes) {
                    setTimeout(() => {
                        showMessage("Amazing! You've placed all shapes correctly!");
                    }, 500);
                }
            } else {
                showMessage("That's okay! Try a different outline.");
                draggable.style.opacity = '1';
            }
        }

        // Touch events for mobile
        let touchStartX = 0;
        let touchStartY = 0;
        let draggedElement = null;

        function handleTouchStart(e) {
            e.preventDefault();
            const touch = e.touches[0];
            touchStartX = touch.clientX;
            touchStartY = touch.clientY;
            draggedElement = e.target;
           
            draggedElement.classList.add('dragging');
            draggedElement.style.opacity = '0.4';
        }

        function handleTouchMove(e) {
            if (!draggedElement) return;
            e.preventDefault();
           
            const touch = e.touches[0];
            const deltaX = touch.clientX - touchStartX;
            const deltaY = touch.clientY - touchStartY;
           
            draggedElement.style.position = 'fixed';
            draggedElement.style.left = (touch.clientX - draggedElement.offsetWidth / 2) + 'px';
            draggedElement.style.top = (touch.clientY - draggedElement.offsetHeight / 2) + 'px';
            draggedElement.style.zIndex = '1000';
        }

        function handleTouchEnd(e) {
            if (!draggedElement) return;
           
            const touch = e.changedTouches[0];
            const elements = document.elementsFromPoint(touch.clientX, touch.clientY);
            const dropzone = elements.find(el => el.classList.contains('shape-outline'));
           
            if (dropzone) {
                // Check if shape matches outline
                const shapeType = draggedElement.dataset.shapeType;
                const outlineType = dropzone.dataset.shapeType;
               
                if (shapeType === outlineType) {
                    // Position the shape inside the outline
                    draggedElement.style.position = 'absolute';
                    draggedElement.style.top = '50%';
                    draggedElement.style.left = '50%';
                    draggedElement.style.transform = 'translate(-50%, -50%)';
                    draggedElement.style.margin = '0';
                    dropzone.appendChild(draggedElement);
                   
                    // Make it non-draggable after correct placement
                    draggedElement.draggable = false;
                    draggedElement.classList.remove('dragging');
                    draggedElement.style.opacity = '1';
                    draggedElement.style.cursor = 'default';
                   
                    shapesPlaced++;
                   
                    // Show success message
                    showSuccessAnimation(dropzone);
                    showMessage("Perfect! You found the right home!");
                   
                    // Check if all shapes are placed
                    if (shapesPlaced === totalShapes) {
                        setTimeout(() => {
                            showMessage("Amazing! You've placed all shapes correctly!");
                        }, 500);
                    }
                } else {
                    showMessage("That's okay! Try a different outline.");
                }
            }
           
            // Reset dragged element
            draggedElement.classList.remove('dragging');
            draggedElement.style.opacity = '1';
            draggedElement.style.position = '';
            draggedElement.style.left = '';
            draggedElement.style.top = '';
            draggedElement.style.zIndex = '';
            draggedElement = null;
        }

        function showSuccessAnimation(element) {
            const success = document.createElement('div');
            success.className = 'success-animation';
            success.textContent = '✓';
            success.style.position = 'absolute';
            success.style.top = '50%';
            success.style.left = '50%';
            element.appendChild(success);
           
            setTimeout(() => {
                success.remove();
            }, 1000);
        }

        // =============== LEVEL 2: CLOCK GAME - FIXED WITH PROPER NUMBER POSITIONS ===============
        function initializeClockGame() {
            // Generate clock numbers with proper positions like a real clock
            const clockNumbers = document.getElementById('clockNumbers');
            clockNumbers.innerHTML = '';
           
            // Position numbers like a real clock (12 at top, 3 at right, etc.)
            const positions = [
                {num: 12, top: '15%', left: '50%'},
                {num: 1, top: '25%', left: '75%'},
                {num: 2, top: '40%', left: '90%'},
                {num: 3, top: '60%', left: '95%'},
                {num: 4, top: '80%', left: '90%'},
                {num: 5, top: '90%', left: '75%'},
                {num: 6, top: '95%', left: '50%'},
                {num: 7, top: '90%', left: '25%'},
                {num: 8, top: '80%', left: '10%'},
                {num: 9, top: '60%', left: '5%'},
                {num: 10, top: '40%', left: '10%'},
                {num: 11, top: '25%', left: '25%'}
            ];
           
            positions.forEach(pos => {
                const number = document.createElement('div');
                number.className = 'clock-number';
                number.style.top = pos.top;
                number.style.left = pos.left;
                number.textContent = pos.num;
                clockNumbers.appendChild(number);
            });
           
            // Set a random time target
            generateRandomTime();
           
            // Set up clock dragging
            setupClockDragging();
           
            // Set initial clock position to match target
            updateClockHandsToTarget();
        }

        function setupClockDragging() {
            const clock = document.getElementById('clock');
            const hourHand = document.getElementById('hourHand');
            const minuteHand = document.getElementById('minuteHand');
           
            // Mouse events
            clock.addEventListener('mousedown', startDrag);
            document.addEventListener('mousemove', drag);
            document.addEventListener('mouseup', stopDrag);
           
            // Touch events
            clock.addEventListener('touchstart', startDragTouch, { passive: false });
            document.addEventListener('touchmove', dragTouch, { passive: false });
            document.addEventListener('touchend', stopDrag);
           
            function startDrag(e) {
                isDraggingClock = true;
                const rect = clock.getBoundingClientRect();
                const centerX = rect.left + rect.width / 2;
                const centerY = rect.top + rect.height / 2;
                const angle = calculateAngle(e.clientX, e.clientY, centerX, centerY);
               
                // Determine which hand is closer to the click
                const hourAngle = getHandAngle(hourHand);
                const minuteAngle = getHandAngle(minuteHand);
                const hourDiff = Math.abs(hourAngle - angle);
                const minuteDiff = Math.abs(minuteAngle - angle);
               
                draggedHand = hourDiff < minuteDiff ? hourHand : minuteHand;
                e.preventDefault();
            }
           
            function startDragTouch(e) {
                isDraggingClock = true;
                const touch = e.touches[0];
                const rect = clock.getBoundingClientRect();
                const centerX = rect.left + rect.width / 2;
                const centerY = rect.top + rect.height / 2;
                const angle = calculateAngle(touch.clientX, touch.clientY, centerX, centerY);
               
                const hourAngle = getHandAngle(hourHand);
                const minuteAngle = getHandAngle(minuteHand);
                const hourDiff = Math.abs(hourAngle - angle);
                const minuteDiff = Math.abs(minuteAngle - angle);
               
                draggedHand = hourDiff < minuteDiff ? hourHand : minuteHand;
                e.preventDefault();
            }
           
            function drag(e) {
                if (!isDraggingClock || !draggedHand) return;
               
                const rect = clock.getBoundingClientRect();
                const centerX = rect.left + rect.width / 2;
                const centerY = rect.top + rect.height / 2;
                const angle = calculateAngle(e.clientX, e.clientY, centerX, centerY);
               
                updateHandAngle(draggedHand, angle);
                e.preventDefault();
            }
           
            function dragTouch(e) {
                if (!isDraggingClock || !draggedHand) return;
               
                const touch = e.touches[0];
                const rect = clock.getBoundingClientRect();
                const centerX = rect.left + rect.width / 2;
                const centerY = rect.top + rect.height / 2;
                const angle = calculateAngle(touch.clientX, touch.clientY, centerX, centerY);
               
                updateHandAngle(draggedHand, angle);
                e.preventDefault();
            }
           
            function stopDrag() {
                isDraggingClock = false;
                draggedHand = null;
            }
        }

        function calculateAngle(x, y, centerX, centerY) {
            const dx = x - centerX;
            const dy = y - centerY;
            let angle = Math.atan2(dy, dx) * 180 / Math.PI + 90;
            if (angle < 0) angle += 360;
            return angle;
        }

        function getHandAngle(hand) {
            const transform = hand.style.transform || 'translateX(-50%) rotate(0deg)';
            const match = transform.match(/rotate\(([-0-9.]+)deg\)/);
            return match ? parseFloat(match[1]) : 0;
        }

        function updateHandAngle(hand, angle) {
            if (hand.id === 'minuteHand') {
                // Snap to 6-degree increments for minutes (each minute = 6 degrees)
                angle = Math.round(angle / 6) * 6;
            } else {
                // For hour hand, make it move with minutes too
                const minuteAngle = getHandAngle(document.getElementById('minuteHand'));
                angle = (Math.round(angle / 30) * 30) + (minuteAngle / 12);
            }
           
            hand.style.transform = `translateX(-50%) rotate(${angle}deg)`;
        }

        function generateRandomTime() {
            const hours = Math.floor(Math.random() * 12) + 1;
            const minutes = Math.floor(Math.random() * 12) * 5; // 0, 5, 10, ... 55
            const period = Math.random() > 0.5 ? "PM" : "AM";
           
            currentTimeTarget = { hours, minutes, period };
           
            const timeDisplay = document.getElementById('timeDisplay');
            const minutesDisplay = minutes < 10 ? `0${minutes}` : minutes;
            timeDisplay.textContent = `${hours}:${minutesDisplay} ${period}`;
        }

        function updateClockHandsToTarget() {
            const hourHand = document.getElementById('hourHand');
            const minuteHand = document.getElementById('minuteHand');
           
            // Calculate angles
            const minuteAngle = currentTimeTarget.minutes * 6; // 360/60 = 6 degrees per minute
            const hourAngle = (currentTimeTarget.hours % 12) * 30 + (currentTimeTarget.minutes / 2); // 360/12 = 30 degrees per hour
           
            // Apply angles
            hourHand.style.transform = `translateX(-50%) rotate(${hourAngle}deg)`;
            minuteHand.style.transform = `translateX(-50%) rotate(${minuteAngle}deg)`;
        }

        function checkTime() {
            const hourHand = document.getElementById('hourHand');
            const minuteHand = document.getElementById('minuteHand');
           
            // Get current angles
            const hourAngle = getHandAngle(hourHand);
            const minuteAngle = getHandAngle(minuteHand);
           
            // Convert angles to time
            const minute = Math.round(minuteAngle / 6);
            const adjustedMinute = minute === 60 ? 0 : minute;
            const hour = Math.round((hourAngle - (adjustedMinute / 2)) / 30) % 12;
            const adjustedHour = hour === 0 ? 12 : hour;
           
            // Check if close enough to target (allow some tolerance)
            const hourDiff = Math.abs(adjustedHour - currentTimeTarget.hours);
            const minuteDiff = Math.abs(adjustedMinute - currentTimeTarget.minutes);
           
            // Adjust for 12-hour format
            const hourCheck = hourDiff === 0 || hourDiff === 11;
            const minuteCheck = minuteDiff <= 5;
           
            if (hourCheck && minuteCheck) {
                showMessage("Excellent! You set the clock perfectly!");
            } else {
                showMessage("Good effort! Time can be tricky. Keep practicing.");
            }
        }

